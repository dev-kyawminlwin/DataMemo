DATABASE_URL="postgresql://datamemo:datamemo@localhost:5432/datamemo?schema=public"

PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Auth (set real secrets in .env; do not commit)
JWT_ACCESS_SECRET="change-me"
JWT_ACCESS_TTL_SECONDS="900"

# Optional: 32-byte key (base64) for AES-256-GCM on stored ad passwords.
# If omitted, a key is derived from JWT_ACCESS_SECRET (fine for local dev only).
# CREDENTIALS_ENCRYPTION_KEY=""

# Optional: used by `npm run db:seed` (apps/api)
SEED_ADMIN_EMAIL="admin@datamemo.local"
SEED_ADMIN_PASSWORD="changeme"
